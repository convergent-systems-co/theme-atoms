---
import Layout from '../layouts/Layout.astro';
import TerminalPreview from '../components/TerminalPreview';
import { loadThemes } from '../lib/themes';

const themes = loadThemes();
const featured = themes.find((t) => t.meta.id === 'nord-powerline') ?? themes[0];
---
<Layout title="THEME-Atoms — Terminal themes for aish and beyond" section="home">
  <section class="hero">
    <p class="kicker">A *-Atoms catalog</p>
    <h1>Terminal themes,<br/>civilization-grade.</h1>
    <p class="lead">Self-contained TOML themes for aish, served from one URL. Composable palette, prompt, separators, and glyph sets. One fetch, deterministic render, zero magic.</p>
    <div class="cta">
      <a class="btn primary" href="/themes">Browse themes</a>
      <a class="btn" href="/builder">Open the builder</a>
      <a class="btn ghost" href="/install">Install aish</a>
    </div>
  </section>

  <section class="featured">
    <p class="kicker">Featured</p>
    <h2>{featured.meta.display_name}</h2>
    <p class="muted">{featured.meta.description}</p>
    <div class="preview-wrap">
      <TerminalPreview theme={featured} client:load />
    </div>
    <p><a href={`/themes/${featured.meta.id}`}>View {featured.meta.id} →</a></p>
  </section>

  <section class="props">
    <h2>What makes a theme civilization-grade</h2>
    <div class="grid">
      <div class="prop">
        <h3>Self-contained</h3>
        <p>One TOML file per theme. Palette inlined. No second fetch.</p>
      </div>
      <div class="prop">
        <h3>Versioned</h3>
        <p>Every theme carries a semver. Schema pinned at <code>theme-v1.json</code>.</p>
      </div>
      <div class="prop">
        <h3>Composable</h3>
        <p>Prompt segments, separator, glyphs, role colors — independent dials.</p>
      </div>
      <div class="prop">
        <h3>Machine-readable</h3>
        <p>JSON-Schema validated in CI. Aish caches and renders deterministically.</p>
      </div>
      <div class="prop">
        <h3>Open</h3>
        <p>Apache-2.0. Themes ship as PRs against the public repo.</p>
      </div>
      <div class="prop">
        <h3>Durable</h3>
        <p>Static URLs at <code>theme-atoms.com/themes/&lt;id&gt;.toml</code>. No vendor APIs in the hot path.</p>
      </div>
    </div>
  </section>

  <section class="howto">
    <h2>Use a theme in 5 seconds</h2>
    <pre><code>aish theme set nord-powerline</code></pre>
    <p>aish fetches <code>https://theme-atoms.com/themes/nord-powerline.toml</code>, caches it, renders. Switch back with <code>aish theme set default</code>.</p>
  </section>

  <style>
    .hero { padding: 24px 0 48px; }
    .kicker { color: var(--text-tertiary); font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 8px; }
    .hero h1 { font-size: 56px; font-weight: 800; letter-spacing: -0.02em; margin: 0 0 16px; }
    .lead { font-size: 19px; color: var(--text-secondary); max-width: 640px; }
    .cta { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }
    .btn { padding: 10px 18px; border-radius: 8px; text-decoration: none; font-weight: 500; font-size: 14px; border: 1px solid var(--surface-elevated); color: var(--text-primary); }
    .btn.primary { background: var(--primary); color: #000; border-color: var(--primary); }
    .btn.primary:hover { background: var(--primary-hover); }
    .btn.ghost { color: var(--text-secondary); }
    .btn:hover { border-color: var(--primary); }

    .featured { padding: 32px 0; }
    .featured .muted { color: var(--text-tertiary); }
    .preview-wrap { max-width: 720px; margin: 16px 0; }

    .props .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 16px; }
    .prop { background: var(--surface); padding: 16px; border-radius: 8px; }
    .prop h3 { margin: 0 0 6px; font-size: 15px; color: var(--text-primary); }
    .prop p { margin: 0; font-size: 13px; color: var(--text-secondary); }

    .howto pre { max-width: 480px; }
  </style>
</Layout>
