---
import Layout from '../../layouts/Layout.astro';
import { loadFonts, fontFaceCss } from '../../lib/fonts';

const fonts = loadFonts();

// Inline @font-face blocks for the regular weight of each font so previews
// render in the actual face. Browsers lazy-load via font-display: swap, so
// initial paint isn't blocked.
const fontFaces = fonts.map(fontFaceCss).join('\n');
---
<Layout title="Fonts — Theme Atoms" section="fonts">
  <header>
    <p class="kicker">Catalog</p>
    <h1>Nerd Fonts</h1>
    <p class="lead">{fonts.length} patched programmer fonts with ~10,000 Nerd Font glyphs each (Powerline, Material Icons, FontAwesome, Devicons, Octicons, Codicons). Pair any of them with a theme.</p>
    <p class="meta">All files self-hosted at <code>cdn.brand-atoms.com</code>. License is per-font (typically OFL-1.1).</p>
  </header>

  <input id="font-filter" class="filter" type="search" placeholder="Filter fonts…" aria-label="Filter fonts" />

  <div class="grid" id="font-grid">
    {fonts.map((f) => (
      <a class="card" href={`/fonts/${f.id}`} data-name={f.name.toLowerCase()} data-family={f.family.toLowerCase()}>
        <div class="sample" style={`font-family: ${JSON.stringify(f.family)}, ui-monospace, monospace`}>
          <div class="big">aA Bb 123</div>
          <div class="small">{'<>= != => 0Ol1Il |'}</div>
          <div class="glyphs">     </div>
        </div>
        <div class="body">
          <h3 style={`font-family: ${JSON.stringify(f.family)}, ui-monospace, monospace`}>{f.family}</h3>
          <p class="id"><code>{f.id}</code> · v{f.version}</p>
          <p class="meta">
            {f.weights.length} weight{f.weights.length === 1 ? '' : 's'} ·
            {f.styles.includes('italic') ? ' italic ·' : ''} {f.license}
          </p>
        </div>
      </a>
    ))}
  </div>

  <p class="empty" id="font-empty" hidden>No fonts match that filter.</p>

  <script>
    const input = document.getElementById('font-filter') as HTMLInputElement;
    const grid = document.getElementById('font-grid')!;
    const empty = document.getElementById('font-empty')!;
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      grid.querySelectorAll<HTMLElement>('.card').forEach((card) => {
        const name = card.dataset.name ?? '';
        const family = card.dataset.family ?? '';
        const match = !q || name.includes(q) || family.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      empty.hidden = visible > 0;
    });
  </script>

  <style is:global set:html={`<style>${fontFaces}</style>`}></style>
  <style>
    .kicker { color: var(--text-tertiary); font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 4px; }
    .lead { color: var(--text-secondary); max-width: 720px; }
    .meta { color: var(--text-tertiary); font-size: 13px; }

    .filter { width: 100%; max-width: 400px; padding: 10px 14px; margin: 16px 0 24px; border-radius: 8px; border: 1px solid var(--surface-elevated); background: var(--surface); color: var(--text-primary); font-size: 14px; font-family: inherit; }

    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .card { display: block; background: var(--surface); border-radius: 12px; padding: 16px; text-decoration: none; color: var(--text-primary); border: 1px solid transparent; transition: border-color 0.15s, transform 0.15s; }
    .card:hover { border-color: var(--primary); transform: translateY(-2px); }
    .sample { background: var(--surface-elevated); padding: 14px; border-radius: 8px; line-height: 1.3; }
    .sample .big { font-size: 26px; }
    .sample .small { font-size: 13px; color: var(--text-tertiary); margin-top: 4px; }
    .sample .glyphs { font-size: 18px; color: var(--text-secondary); margin-top: 4px; }
    .card .body h3 { margin: 12px 0 4px; font-size: 18px; font-weight: 500; }
    .card .id, .card .meta { font-size: 12px; color: var(--text-tertiary); margin: 0; }
    .empty { color: var(--text-tertiary); font-style: italic; padding: 24px; text-align: center; }
  </style>
</Layout>
