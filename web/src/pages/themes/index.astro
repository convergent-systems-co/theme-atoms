---
import Layout from '../../layouts/Layout.astro';
import TerminalPreview from '../../components/TerminalPreview';
import { loadThemes } from '../../lib/themes';

const themes = loadThemes();
---
<Layout title="Themes — Theme Atoms" section="themes">
  <header>
    <p class="kicker">Catalog</p>
    <h1>Themes</h1>
    <p class="lead">{themes.length} self-contained TOML theme{themes.length === 1 ? '' : 's'}. Served at <code>theme-atoms.com/themes/&lt;id&gt;.toml</code>.</p>
  </header>

  <div class="grid">
    {themes.map((t) => (
      <a class="card" href={`/themes/${t.meta.id}`}>
        <div class="preview"><TerminalPreview theme={t} client:visible /></div>
        <div class="body">
          <h3>{t.meta.display_name}</h3>
          <p class="id"><code>{t.meta.id}</code> · v{t.meta.version}</p>
          <p class="desc">{t.meta.description ?? 'Self-contained terminal theme.'}</p>
          <p class="meta">
            {(t.prompt.segments ?? []).length} segments · <code>{t.prompt.separator ?? 'none'}</code> separator · <code>{t.prompt.glyphs ?? 'ascii'}</code> glyphs
          </p>
        </div>
      </a>
    ))}
  </div>

  <style>
    .kicker { color: var(--text-tertiary); font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 4px; }
    .lead { color: var(--text-secondary); max-width: 640px; }

    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 20px; margin-top: 24px; }
    .card { display: block; background: var(--surface); border-radius: 12px; padding: 16px; text-decoration: none; color: var(--text-primary); border: 1px solid transparent; transition: border-color 0.15s, transform 0.15s; }
    .card:hover { border-color: var(--primary); transform: translateY(-2px); }
    .preview { margin-bottom: 12px; }
    .card .body h3 { margin: 0 0 4px; font-size: 17px; }
    .card .id, .card .meta { font-size: 12px; color: var(--text-tertiary); margin: 0; }
    .card .desc { font-size: 13px; color: var(--text-secondary); margin: 8px 0; }
  </style>
</Layout>
